<?php

class ClienteController extends Controller
{
    public function index()
    {
        AuthMiddleware::verificarLogin();

        $clienteModel = new Cliente();
        $clientes = $clienteModel->listarPorLoja($_SESSION['LOJA']['id_loja']);

        // Carregar cardgames de cada cliente
        foreach ($clientes as &$cliente) {
            $cliente['cardgames'] = $clienteModel->listarCardgames($cliente['id_cliente']);
        }

        $this->view('cliente/index', [
            'clientes' => $clientes
        ]);
    }

    public function criar()
    {
        AuthMiddleware::verificarLogin();

        // Carrega todos os cardgames
        require_once __DIR__ . '/../Models/CardGame.php';
        $cardgameModel = new CardGame();
        $cardgames = $cardgameModel->listarTodos();

        $this->view('cliente/form', [
            'cardgames' => $cardgames
        ]);
    }

    public function editar($id)
    {
        AuthMiddleware::verificarLogin();

        require_once __DIR__ . '/../Models/CardGame.php';
        $cardgameModel = new CardGame();
        $cardgames = $cardgameModel->listarTodos();

        $clienteModel = new Cliente();
        $cliente = $clienteModel->buscar($id, $_SESSION['LOJA']['id_loja']);

        // Carregar cardgames já vinculados ao cliente
        $cardgamesCliente = $clienteModel->listarCardgames($id);

        $this->view('cliente/form', [
            'cliente'          => $cliente,
            'cardgames'        => $cardgames,
            'cardgamesCliente' => $cardgamesCliente
        ]);
    }

    public function salvar()
    {
        $clienteModel = new Cliente();

        // limpa o telefone antes de salvar
        $telefone = $_POST['telefone'] ?? '';
        $telefone = preg_replace('/\D/', '', $telefone); // remove tudo que não for número

        $dadosCliente = [
            'nome'     => $_POST['nome'],
            'email'    => $_POST['email'],
            'telefone' => $telefone
        ];

        $id_loja   = $_SESSION['LOJA']['id_loja'];
        $cardgames = $_POST['cardgames'] ?? [];

        $resultado = $clienteModel->criarOuVincular($dadosCliente, $id_loja, $cardgames);

        if ($resultado['novo']) {
            $_SESSION['flash'] = "Cliente cadastrado com sucesso!";
        } else {
            $_SESSION['flash'] = "Cliente já existia, apenas vinculado à loja.";
        }

        // CORREÇÃO: Redirecionamento dinâmico
        header('Location: ' . $this->baseUrl . 'cliente');
        exit;
    }


    public function atualizar($id)
    {
        $clienteModel = new Cliente();

        // limpa o telefone antes de atualizar
        $telefone = $_POST['telefone'] ?? '';
        $telefone = preg_replace('/\D/', '', $telefone); // remove tudo que não for número

        $dadosCliente = [
            'nome'     => $_POST['nome'],
            'email'    => $_POST['email'],
            'telefone' => $telefone
        ];

        $cardgames = $_POST['cardgames'] ?? [];

        $clienteModel->atualizar($id, $dadosCliente, $cardgames);

        $_SESSION['flash'] = "Cliente atualizado com sucesso!";

        // CORREÇÃO: Redirecionamento dinâmico
        header('Location: ' . $this->baseUrl . 'cliente');
        exit;
    }

    public function verificarTelefone()
    {
        header('Content-Type: application/json; charset=utf-8');

        $telefone = preg_replace('/\D/', '', $_GET['telefone'] ?? '');

        if (empty($telefone)) {
            echo json_encode(["encontrado" => false]);
            return;
        }

        // Caminho correto para o model
        require_once __DIR__ . "/../Models/Cliente.php";
        $clienteModel = new Cliente();

        $cliente = $clienteModel->buscarPorTelefone($telefone);

        if ($cliente) {
            echo json_encode([
                "encontrado" => true,
                "nome" => $cliente['nome'],
                "email" => $cliente['email'],
                "telefone" => $cliente['telefone']
            ]);
        } else {
            echo json_encode(["encontrado" => false]);
        }
    }

    public function excluir($id)
    {
        AuthMiddleware::verificarLogin();

        $id_loja = $_SESSION['LOJA']['id_loja'];
        $clienteModel = new Cliente();

        if ($clienteModel->excluir($id, $id_loja)) {
            $_SESSION['flash'] = "Vínculo com o cliente removido com sucesso! O histórico de pedidos foi preservado.";
        }

        // CORREÇÃO: Redirecionamento dinâmico
        header('Location: ' . $this->baseUrl . 'cliente');
        exit;
    }

	// Rota para o QR Code (Lojista)
	public function qrcode_perfil()
	{
		AuthMiddleware::verificarLogin();

		$id_loja = $_SESSION['LOJA']['id_loja'];
		$db = Database::getInstance();

		$stmt = $db->prepare("SELECT * FROM lojas WHERE id_loja = :id");
		$stmt->execute(['id' => $id_loja]);
		$loja = $stmt->fetch(PDO::FETCH_ASSOC);

		// Chame com o V maiúsculo e APENAS 2 parâmetros
		$this->rawView('cliente/qrcode_perfil', [
			'loja' => $loja
		]);
	}

	// Rota para a busca do perfil (Cliente Final)
	public function perfil($id_loja)
	{
		$db = Database::getInstance();
		$stmt = $db->prepare("SELECT nome_loja, logo, cor_tema, id_loja FROM lojas WHERE id_loja = :id");
		$stmt->execute(['id' => $id_loja]);
		$loja = $stmt->fetch(PDO::FETCH_ASSOC);

		// Chame com o V maiúsculo e APENAS 2 parâmetros
		$this->rawView('cliente/perfil_publico', [
			'id_loja' => $id_loja,
			'loja' => $loja
		]);
	}

	// Rota para o resultado da consulta (Cliente Final)
	public function consultar()
	{
		$telefone = preg_replace('/\D/', '', $_POST['telefone'] ?? '');
		$id_loja = $_POST['id_loja'] ?? '';

		$clienteModel = new Cliente();
		$perfil = $clienteModel->buscarPorTelefoneELoja($telefone, $id_loja);

		$db = Database::getInstance();
		$stmt = $db->prepare("SELECT nome_loja, logo, cor_tema, id_loja FROM lojas WHERE id_loja = :id");
		$stmt->execute(['id' => $id_loja]);
		$loja = $stmt->fetch(PDO::FETCH_ASSOC);

		if ($perfil) {
			$id_cliente_logado = $perfil['id_cliente'];
			$pedidos = $clienteModel->listarHistoricoPedidos($id_cliente_logado, $id_loja);
			$rankings = $clienteModel->obterRankingPlayer($id_cliente_logado, $id_loja);

			// --- LÓGICA PARA BUSCAR RANKINGS (MENSAL E ANUAL) ---
			if (!empty($rankings)) {
				foreach ($rankings as &$rank) {
					$id_game = $rank['id_cardgame'];

					// 1. QUERY BASE PARA O TOP 5 GERAL
					$sqlBase = "SELECT c.nome, SUM(tr.pontos_totais) as pontos, tr.id_cliente 
								FROM torneio_resultados_finais tr
								JOIN clientes c ON c.id_cliente = tr.id_cliente
								JOIN torneios t ON t.id_torneio = tr.id_torneio
								WHERE t.id_cardgame = :id_game AND t.id_loja = :id_loja";

					// BUSCA TOP 5 MENSAL
					$sqlMensal = $sqlBase . " AND MONTH(t.data_criacao) = MONTH(CURRENT_DATE()) 
											 AND YEAR(t.data_criacao) = YEAR(CURRENT_DATE()) 
											 GROUP BY tr.id_cliente ORDER BY pontos DESC LIMIT 5";
					$stmtM = $db->prepare($sqlMensal);
					$stmtM->execute(['id_game' => $id_game, 'id_loja' => $id_loja]);
					$rank['top5_mensal'] = $stmtM->fetchAll(PDO::FETCH_ASSOC);

					// BUSCA TOP 5 ANUAL
					$sqlAnual = $sqlBase . " AND YEAR(t.data_criacao) = YEAR(CURRENT_DATE()) 
											GROUP BY tr.id_cliente ORDER BY pontos DESC LIMIT 5";
					$stmtA = $db->prepare($sqlAnual);
					$stmtA->execute(['id_game' => $id_game, 'id_loja' => $id_loja]);
					$rank['top5_anual'] = $stmtA->fetchAll(PDO::FETCH_ASSOC);


					// 2. BUSCA DE SALDO INDIVIDUAL DO CLIENTE (PARA A CÉLULA DA ESQUERDA)
					
					// Saldo Mensal Individual
					$sqlMeuMensal = "SELECT SUM(tr.pontos_totais) as pontos 
									 FROM torneio_resultados_finais tr
									 JOIN torneios t ON t.id_torneio = tr.id_torneio
									 WHERE t.id_cardgame = :id_game 
									   AND t.id_loja = :id_loja 
									   AND tr.id_cliente = :id_cliente
									   AND MONTH(t.data_criacao) = MONTH(CURRENT_DATE())
									   AND YEAR(t.data_criacao) = YEAR(CURRENT_DATE())";
					$stmtMeuM = $db->prepare($sqlMeuMensal);
					$stmtMeuM->execute(['id_game' => $id_game, 'id_loja' => $id_loja, 'id_cliente' => $id_cliente_logado]);
					$rank['meu_ponto_mensal'] = $stmtMeuM->fetch(PDO::FETCH_ASSOC)['pontos'] ?? 0;

					// Saldo Anual Individual
					$sqlMeuAnual = "SELECT SUM(tr.pontos_totais) as pontos 
									FROM torneio_resultados_finais tr
									JOIN torneios t ON t.id_torneio = tr.id_torneio
									WHERE t.id_cardgame = :id_game 
									  AND t.id_loja = :id_loja 
									  AND tr.id_cliente = :id_cliente
									  AND YEAR(t.data_criacao) = YEAR(CURRENT_DATE())";
					$stmtMeuA = $db->prepare($sqlMeuAnual);
					$stmtMeuA->execute(['id_game' => $id_game, 'id_loja' => $id_loja, 'id_cliente' => $id_cliente_logado]);
					$rank['meu_ponto_anual'] = $stmtMeuA->fetch(PDO::FETCH_ASSOC)['pontos'] ?? 0;
				}
			}
			// --------------------------------------------------

			$this->rawView('cliente/perfil_publico', [
				'perfil' => $perfil,
				'pedidos' => $pedidos,
				'rankings' => $rankings,
				'loja' => $loja,
				'id_loja' => $id_loja
			]);

		} else {
			header("Location: " . $this->baseUrl . "cliente/perfil/$id_loja?erro=1");
			exit;
		}
	}

}
